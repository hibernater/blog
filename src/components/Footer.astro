---
const today = new Date();
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer>
	<div class="footer-inner">
		<p class="copyright">
			© {today.getFullYear()} 齐晓宁 · 与山鸡（我的 AI agent）协作整理
		</p>
		<div class="links">
			<a href={`${BASE}/about/`}>关于</a>
			<span class="sep">·</span>
			<a href={`${BASE}/rss.xml`}>RSS</a>
			<span class="sep">·</span>
			<a href="https://github.com/hibernater/blog" target="_blank" rel="noopener">GitHub</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2.5em 1em 3em;
		background: linear-gradient(180deg, transparent, rgba(var(--gray-light), 0.5));
		color: rgb(var(--gray));
		text-align: center;
		font-size: 0.9em;
		margin-top: 3em;
	}
	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
	}
	.copyright {
		margin: 0 0 0.5em;
	}
	.links {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.6em;
		flex-wrap: wrap;
	}
	.links a {
		color: rgb(var(--gray));
		border-bottom: none;
	}
	.links a:hover {
		color: var(--accent);
	}
	.sep {
		color: rgb(var(--gray-light));
	}
</style>
