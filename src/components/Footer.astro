---
const today = new Date();
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
	<div class="wrap">
		<p>© {today.getFullYear()} 齐晓宁 · 与山鸡（我的 AI agent）协作整理</p>
		<p class="links">
			<a href={`${BASE}/about/`}>关于</a>
			<span>·</span>
			<a href={`${BASE}/rss.xml`}>RSS</a>
			<span>·</span>
			<a href="https://github.com/hibernater/blog" target="_blank" rel="noopener">GitHub</a>
		</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid #e8e8e8;
		padding: 28px 0 42px;
		margin-top: 42px;
		color: #777;
		font-size: 14px;
	}
	.wrap {
		max-width: 800px;
		padding: 0 30px;
		margin: 0 auto;
	}
	p { margin: 0 0 8px; }
	.links {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}
	a,
	a:visited {
		color: #2a7ae2;
		text-decoration: none;
		border-bottom: none;
	}
	a:hover {
		color: #000;
		text-decoration: underline;
	}
</style>
