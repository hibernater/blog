---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="site-header">
	<nav class="wrap">
		<a class="site-title" href={`${BASE}/`}>{SITE_TITLE}</a>
		<div class="site-nav">
			<HeaderLink href={`${BASE}/`}>首页</HeaderLink>
			<HeaderLink href={`${BASE}/about/`}>关于</HeaderLink>
			<a href="https://github.com/hibernater/blog" target="_blank" rel="noopener">GitHub</a>
			<a href={`${BASE}/rss.xml`}>RSS</a>
		</div>
	</nav>
</header>

<style>
	.site-header {
		border-top: 5px solid #333;
		border-bottom: 1px solid #e8e8e8;
		background: #fff;
		min-height: 56px;
	}
	.wrap {
		max-width: 800px;
		padding: 0 30px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 56px;
	}
	.site-title,
	.site-title:visited {
		color: #333;
		font-size: 22px;
		line-height: 56px;
		letter-spacing: -0.5px;
		text-decoration: none;
		border-bottom: none;
	}
	.site-title:hover {
		color: #000;
		text-decoration: none;
	}
	.site-nav {
		display: flex;
		align-items: center;
		gap: 18px;
		font-size: 14px;
	}
	.site-nav a,
	.site-nav a:visited {
		color: #727272;
		text-decoration: none;
		border-bottom: none;
		padding: 0;
	}
	.site-nav a:hover,
	.site-nav a.active {
		color: #111;
		text-decoration: underline;
		border-bottom: none;
	}
	@media (max-width: 720px) {
		.wrap {
			padding: 0 18px;
			align-items: flex-start;
			flex-direction: column;
			gap: 4px;
			padding-top: 10px;
			padding-bottom: 10px;
		}
		.site-title { line-height: 1.3; }
		.site-nav { gap: 12px; flex-wrap: wrap; }
	}
</style>
