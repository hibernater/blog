---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { tags?: string[] };

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* 文章页专属优化 — PC 阅读体验 */
			article {
				max-width: 720px;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 1.5em;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.post-header {
				margin: 1em 0 2.5em;
				padding-bottom: 1.8em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-header h1 {
				margin: 0 0 0.7em;
				font-size: 2.25em;
				line-height: 1.25;
				color: rgb(var(--black));
				font-weight: 700;
				letter-spacing: -0.015em;
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.92em;
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.8em;
			}
			.post-meta .tags {
				display: inline-flex;
				gap: 0.4em;
				flex-wrap: wrap;
			}
			.post-meta .tag {
				font-size: 0.85em;
				padding: 0.1em 0.55em;
				background: rgba(var(--accent), 0.08);
				color: var(--accent);
				border-radius: 4px;
			}
			.last-updated-on {
				font-style: italic;
			}

			/* === 正文排版 (核心) === */
			.prose {
				font-size: 18px;
				line-height: 1.85;
				color: #2d3748;
				letter-spacing: 0.01em;
			}
			.prose p {
				margin: 0 0 1.3em;
				text-align: justify;
				text-justify: inter-ideograph;
			}
			.prose h2 {
				margin: 2.2em 0 0.8em;
				font-size: 1.5em;
				font-weight: 700;
				line-height: 1.4;
				color: rgb(var(--black));
				padding-bottom: 0.3em;
				border-bottom: 1px solid rgba(var(--gray-light), 0.8);
			}
			.prose h3 {
				margin: 2em 0 0.7em;
				font-size: 1.22em;
				font-weight: 700;
				line-height: 1.4;
				color: rgb(var(--black));
			}
			.prose h4 {
				margin: 1.8em 0 0.6em;
				font-size: 1.08em;
				font-weight: 700;
				color: rgb(var(--black));
			}
			.prose strong {
				color: rgb(var(--black));
				font-weight: 600;
			}
			.prose ul, .prose ol {
				margin: 0 0 1.3em;
				padding-left: 1.8em;
			}
			.prose li {
				margin-bottom: 0.5em;
				line-height: 1.8;
			}
			.prose li > p {
				margin-bottom: 0.5em;
			}
			.prose blockquote {
				margin: 1.6em 0;
				padding: 0.8em 1.3em;
				border-left: 4px solid var(--accent);
				background: rgba(var(--accent), 0.04);
				color: #4a5568;
				font-size: 0.97em;
				border-radius: 0 6px 6px 0;
			}
			.prose blockquote p {
				margin-bottom: 0.5em;
			}
			.prose blockquote p:last-child {
				margin-bottom: 0;
			}
			.prose code {
				font-size: 0.88em;
				padding: 2px 6px;
				background: rgba(var(--gray-light), 0.7);
				color: #c7254e;
				border-radius: 4px;
				font-family: var(--font-mono);
			}
			.prose pre {
				margin: 1.6em 0;
				padding: 1.3em 1.5em;
				border-radius: 8px;
				overflow-x: auto;
				font-size: 0.92em;
				line-height: 1.65;
			}
			.prose pre code {
				background: none;
				color: inherit;
				padding: 0;
				font-size: 1em;
			}
			.prose table {
				margin: 1.6em 0;
				font-size: 0.95em;
				border-collapse: collapse;
				width: 100%;
			}
			.prose th, .prose td {
				padding: 0.7em 1em;
				border: 1px solid rgb(var(--gray-light));
				line-height: 1.6;
			}
			.prose th {
				background: rgba(var(--gray-light), 0.5);
				font-weight: 600;
				color: rgb(var(--black));
			}
			.prose hr {
				margin: 2.5em 0;
				border: none;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.prose a {
				color: var(--accent);
				border-bottom: 1px solid rgba(59, 91, 219, 0.35);
			}
			.prose a:hover {
				color: var(--accent-dark);
				border-bottom-color: var(--accent);
			}
			.prose img {
				display: block;
				margin: 1.6em auto;
				max-width: 100%;
				border-radius: 8px;
			}

			@media (max-width: 720px) {
				.post-header h1 { font-size: 1.7em; }
				.prose {
					font-size: 16.5px;
					line-height: 1.8;
				}
				.prose p {
					text-align: left;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<header class="post-header">
					<h1>{title}</h1>
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="last-updated-on">
								（更新于 <FormattedDate date={updatedDate} />）
							</span>
						)}
						{tags && tags.length > 0 && (
							<span class="tags">
								{tags.map((t) => <span class="tag">{t}</span>)}
							</span>
						)}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
