---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { tags?: string[] };

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 1.5em;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.post-header {
				margin: 1em 0 2em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-header h1 {
				margin: 0 0 0.6em;
				font-size: 2.1em;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.92em;
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.8em;
			}
			.post-meta .tags {
				display: inline-flex;
				gap: 0.4em;
				flex-wrap: wrap;
			}
			.post-meta .tag {
				font-size: 0.85em;
				padding: 0.1em 0.55em;
				background: rgba(var(--accent), 0.08);
				color: var(--accent);
				border-radius: 4px;
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				.post-header h1 { font-size: 1.6em; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<header class="post-header">
					<h1>{title}</h1>
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="last-updated-on">
								（更新于 <FormattedDate date={updatedDate} />）
							</span>
						)}
						{tags && tags.length > 0 && (
							<span class="tags">
								{tags.map((t) => <span class="tag">{t}</span>)}
							</span>
						)}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
