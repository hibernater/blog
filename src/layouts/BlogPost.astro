---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { tags?: string[] };

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* 文章页专属优化 — 参考 Karpathy 博客：窄栏、轻量、正文克制 */
			article {
				max-width: 800px;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 1.5em;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 6px;
			}
			.post-header {
				margin: 0.8em 0 2em;
				padding-bottom: 1.2em;
				border-bottom: 1px solid #e8e8e8;
			}
			.post-header h1 {
				margin: 0 0 0.6em;
				font-size: 1.65em;
				line-height: 1.25;
				color: #222;
				font-weight: 500;
				letter-spacing: -0.02em;
			}
			.post-meta {
				color: #777;
				font-size: 0.9em;
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.7em;
			}
			.post-meta .tags {
				display: inline-flex;
				gap: 0.35em;
				flex-wrap: wrap;
			}
			.post-meta .tag {
				font-size: 0.82em;
				padding: 0.05em 0.45em;
				background: transparent;
				color: #777;
				border: 1px solid #ddd;
				border-radius: 3px;
			}
			.last-updated-on {
				font-style: italic;
			}

			/* === 正文排版 (核心) === */
			.prose {
				font-size: 15px;
				line-height: 1.68;
				font-weight: 400;
				color: #333;
			}
			.prose p {
				margin: 0 0 1em;
			}
			.prose h1 {
				margin: 1.6em 0 0.7em;
				font-size: 1.7em;
				font-weight: 500;
				line-height: 1.25;
				color: #222;
			}
			.prose h2 {
				margin: 1.8em 0 0.65em;
				font-size: 1.42em;
				font-weight: 500;
				line-height: 1.25;
				color: #222;
				padding-bottom: 0;
				border-bottom: none;
			}
			.prose h3 {
				margin: 1.6em 0 0.55em;
				font-size: 1.18em;
				font-weight: 500;
				line-height: 1.3;
				color: #222;
			}
			.prose h4 {
				margin: 1.4em 0 0.5em;
				font-size: 1em;
				font-weight: 600;
				color: #222;
			}
			.prose strong {
				color: #222;
				font-weight: 600;
			}
			.prose ul, .prose ol {
				margin: 0 0 1em;
				padding-left: 1.45em;
			}
			.prose li {
				margin-bottom: 0.25em;
				line-height: 1.65;
			}
			.prose li > p {
				margin-bottom: 0.35em;
			}
			.prose blockquote {
				margin: 1.35em 0;
				padding: 0.15em 0 0.15em 1em;
				border-left: 4px solid #e8e8e8;
				background: transparent;
				color: #666;
				font-size: 1em;
				font-style: italic;
				border-radius: 0;
			}
			.prose blockquote p {
				margin-bottom: 0.45em;
			}
			.prose blockquote p:last-child {
				margin-bottom: 0;
			}
			.prose code {
				font-size: 0.9em;
				padding: 1px 5px;
				background: #eef;
				border: 1px solid #d5d5e9;
				color: #333;
				border-radius: 3px;
				font-family: var(--font-mono);
			}
			.prose pre {
				margin: 1.3em 0;
				padding: 0.8em 1em;
				border-radius: 3px;
				overflow-x: auto;
				font-size: 0.92em;
				line-height: 1.5;
				background: #eef;
				border: 1px solid #d5d5e9;
			}
			.prose pre code {
				background: none;
				border: none;
				color: inherit;
				padding: 0;
				font-size: 1em;
			}
			.prose table {
				margin: 1.4em 0;
				font-size: 0.92em;
				border-collapse: collapse;
				width: 100%;
			}
			.prose th, .prose td {
				padding: 0.45em 0.65em;
				border: 1px solid #e8e8e8;
				line-height: 1.5;
			}
			.prose th {
				background: #f7f7f7;
				font-weight: 600;
				color: #222;
			}
			.prose hr {
				margin: 2em 0;
				border: none;
				border-top: 1px solid #e8e8e8;
			}
			.prose a {
				color: #2a7ae2;
				border-bottom: none;
			}
			.prose a:hover {
				color: #000;
				text-decoration: underline;
			}
			.prose img {
				display: block;
				margin: 1.4em auto;
				max-width: 100%;
				border-radius: 4px;
			}

			@media (max-width: 720px) {
				article { max-width: 100%; }
				.post-header h1 { font-size: 1.45em; }
				.prose {
					font-size: 15px;
					line-height: 1.65;
				}
				.prose h2 { font-size: 1.28em; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<header class="post-header">
					<h1>{title}</h1>
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="last-updated-on">
								（更新于 <FormattedDate date={updatedDate} />）
							</span>
						)}
						{tags && tags.length > 0 && (
							<span class="tags">
								{tags.map((t) => <span class="tag">{t}</span>)}
							</span>
						)}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
